---
/**
 * Pipeline artifact component — the signature proof of the Figma↔code workflow.
 * Shows two images side by side, each labelled, so a hiring manager can SEE
 * that the design and the shipped implementation match.
 */
interface Props {
  figmaSrc: string;
  codeSrc: string;
  figmaAlt: string;
  codeAlt: string;
  /** Which side was the source, drives the arrow direction label */
  direction?: "figma-to-code" | "code-to-figma";
  caption?: string;
}
const {
  figmaSrc,
  codeSrc,
  figmaAlt,
  codeAlt,
  direction = "figma-to-code",
  caption,
} = Astro.props;

const leftLabel = direction === "figma-to-code" ? "Figma" : "Shipped code";
const rightLabel = direction === "figma-to-code" ? "Shipped code" : "Figma";
const leftSrc = direction === "figma-to-code" ? figmaSrc : codeSrc;
const rightSrc = direction === "figma-to-code" ? codeSrc : figmaSrc;
const leftAlt = direction === "figma-to-code" ? figmaAlt : codeAlt;
const rightAlt = direction === "figma-to-code" ? codeAlt : figmaAlt;
---

<figure class="compare">
  <div class="pair">
    <div class="panel">
      <span class="label">{leftLabel}</span>
      <img src={leftSrc} alt={leftAlt} loading="lazy" />
    </div>
    <div class="arrow" aria-hidden="true">→</div>
    <div class="panel">
      <span class="label">{rightLabel}</span>
      <img src={rightSrc} alt={rightAlt} loading="lazy" />
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .compare {
    margin-block: var(--space-12);
    width: min(100%, 60rem);
    margin-inline: calc((var(--measure) - min(100%, 60rem)) / 2);
  }
  @media (max-width: 48rem) {
    .compare { width: 100%; margin-inline: 0; }
  }

  .pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
  }
  .panel {
    position: relative;
    min-width: 0;
  }
  .label {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    z-index: 1;
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--text);
    color: var(--bg);
  }
  .panel img {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .arrow {
    font-size: var(--step-2);
    color: var(--text-muted);
    line-height: 1;
  }
  figcaption {
    margin-top: var(--space-4);
    font-size: var(--step--1);
    color: var(--text-muted);
    text-align: center;
  }

  /* Stack on mobile; arrow rotates to point downward */
  @media (max-width: 40rem) {
    .pair { grid-template-columns: 1fr; }
    .arrow { transform: rotate(90deg); justify-self: center; }
  }
</style>
