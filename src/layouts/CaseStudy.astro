---
import Base from "./Base.astro";

interface Props {
  /** 1 — title + one-line outcome */
  eyebrow: string; // e.g. "Design system · Concept"
  title: string;
  outcome: string;
  /** 2 — meta row */
  role: string;
  timeline: string;
  tools: string[];
  liveUrl?: string;
  figmaUrl?: string;
  repoUrl?: string;
}
const { eyebrow, title, outcome, role, timeline, tools, liveUrl, figmaUrl, repoUrl } =
  Astro.props;
---

<Base title={`${title} — Case study`} description={outcome}>
  <a class="skip" href="#content">Skip to content</a>

  <article>
    <header class="head">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="outcome">{outcome}</p>

      <dl class="meta">
        <div><dt>Role</dt><dd>{role}</dd></div>
        <div><dt>Timeline</dt><dd>{timeline}</dd></div>
        <div><dt>Tools</dt><dd>{tools.join(", ")}</dd></div>
        {(liveUrl || figmaUrl || repoUrl) && (
          <div class="links">
            <dt>Links</dt>
            <dd>
              {liveUrl && <a href={liveUrl}>Live</a>}
              {figmaUrl && <a href={figmaUrl}>Figma</a>}
              {repoUrl && <a href={repoUrl}>Code</a>}
            </dd>
          </div>
        )}
      </dl>
    </header>

    <div class="prose" id="content">
      <slot />
    </div>
  </article>

  <style>
    .skip {
      position: absolute;
      left: -999px;
    }
    .skip:focus {
      position: static;
      display: inline-block;
      margin: var(--space-4);
    }

    article {
      padding: var(--space-16) var(--space-6) var(--space-24);
    }

    /* Header shares the prose measure so everything lines up on one axis */
    .head {
      max-width: var(--measure);
      margin-inline: auto;
      margin-bottom: var(--space-12);
    }
    .eyebrow {
      font-size: var(--step--1);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin-bottom: var(--space-4);
    }
    h1 {
      font-size: var(--step-4);
      margin-bottom: var(--space-6);
    }
    .outcome {
      font-size: var(--step-2);
      color: var(--text);
      line-height: 1.4;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-6) var(--space-8);
      margin-top: var(--space-8);
      padding-top: var(--space-6);
      border-top: 1px solid var(--border);
    }
    .meta dt {
      font-size: var(--step--1);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: var(--space-1);
    }
    .meta dd { font-size: var(--step-0); }
    .meta .links dd { display: flex; gap: var(--space-4); }

    /* Prose — the 60–75ch measure lives here */
    .prose {
      max-width: var(--measure);
      margin-inline: auto;
    }
    .prose :global(h2) {
      font-size: var(--step-3);
      margin-top: var(--space-16);
      margin-bottom: var(--space-4);
    }
    .prose :global(h3) {
      font-size: var(--step-1);
      margin-top: var(--space-8);
      margin-bottom: var(--space-2);
    }
    .prose :global(p) { margin-block: var(--space-4); }
    .prose :global(ul), .prose :global(ol) {
      margin-block: var(--space-4);
      padding-left: var(--space-6);
    }
    .prose :global(li) { margin-block: var(--space-2); }
    .prose :global(li)::marker { color: var(--text-muted); }
    .prose :global(strong) { font-weight: 650; }

    /* Decisions — a repeatable block: decision + rejected alternative */
    .prose :global(.decision) {
      margin-block: var(--space-6);
      padding: var(--space-6);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
    }
    .prose :global(.decision h3) { margin-top: 0; }
    .prose :global(.decision .rejected) {
      margin-top: var(--space-3);
      padding-top: var(--space-3);
      border-top: 1px solid var(--border);
      font-size: var(--step--1);
      color: var(--text-muted);
    }
  </style>
</Base>
